{
  "compilerOptions": {
    "target": "es2022",
    "moduleDetection": "force",
    "rootDir": "./src",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "types": ["node"],
    "strict": true,
    "exactOptionalPropertyTypes": true,
    "noUncheckedIndexedAccess": true,
    "declaration": false,
    "declarationMap": false,
    "outDir": "./dist",
    "sourceMap": false,
    "isolatedModules": true,
    "noUncheckedSideEffectImports": true,
    "skipLibCheck": true
  }
}
